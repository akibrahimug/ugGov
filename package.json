{
  "name": "ug-gov",
  "private": true,
  "version": "0.0.0",
  "description": "Unified online presence for the Government of Uganda. Monorepo housing the frontend, publishing studio, content schemas and shared design system.",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@ug-gov/frontend",
    "dev:studio": "turbo run dev --filter=@ug-gov/studio",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  }
}
